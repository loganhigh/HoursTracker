rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isFriendOf(userId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(userId));
    }

    // pairId is always sorted lexicographically: min(a,b)_max(a,b)
    function friendshipPairExists(uidA, uidB) {
      return (uidA < uidB
        ? exists(/databases/$(database)/documents/friendships/$(uidA + '_' + uidB))
        : exists(/databases/$(database)/documents/friendships/$(uidB + '_' + uidA)));
    }

    function isFriendOfAny(userId) {
      return isSignedIn()
        && (isFriendOf(userId) || friendshipPairExists(request.auth.uid, userId));
    }

    function canReadSocialContent(ownerUid) {
      return isSignedIn() && (request.auth.uid == ownerUid || isFriendOfAny(ownerUid));
    }

    function isFriendshipParticipant() {
      return isSignedIn()
        && (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
    }

    function validPost(data) {
      return data.authorId == request.auth.uid
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 280
        && data.visibility == 'friendsOnly';
    }

    function validComment(data) {
      return data.authorId == request.auth.uid
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 200;
    }

    // Fields on users/{uid} that only the admin Cloud Functions (Admin SDK)
    // may set. Clients must never write these or they could self-boost.
    function noAdminOnlyFieldsCreate() {
      return !request.resource.data.keys()
        .hasAny(['adminFloorLevel', 'adminFloorPrestige', 'adminEquippedTitle']);
    }

    function noAdminOnlyFieldsUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['adminFloorLevel', 'adminFloorPrestige', 'adminEquippedTitle']);
    }

    match /publicProfiles/{profileUid} {
      allow read: if isSignedIn();
      allow write: if false;

      match /stats/{statDoc} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // Public read-only "Top 5 Hour Trackers" board. Written only by Cloud
    // Functions (Admin SDK bypasses these rules).
    match /leaderboards/{doc} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Live progress for the admin "Refresh all users" bulk job. Only the CEO
    // admin account can read it (so the panel can show real counts instead of
    // an indefinite spinner); only Cloud Functions (Admin SDK) ever write it.
    match /adminOps/{doc} {
      allow read: if isSignedIn() && request.auth.uid == 'msUcdbAbaAaS4HDj52CMs0Vzw8j2';
      allow write: if false;
    }

    match /friendships/{pairId} {
      // Friendship docs are created and updated ONLY by Cloud Functions (Admin
      // SDK, which bypasses these rules) via the two-sided sendFriendRequest /
      // reconcileFriendships flow. A client `create` previously only had to name
      // itself as userA/userB — with no proof the other party consented — and
      // that unilateral write satisfied friendshipPairExists(), unlocking the
      // victim's friends-only content. Clients may read a friendship they take
      // part in and delete it (un-friend / account cleanup) only.
      allow read: if isSignedIn()
        && (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
      allow create, update: if false;
      allow delete: if isFriendshipParticipant();
    }

    match /users/{uid} {
      // Profile docs are readable by any signed-in user so friend-code lookup
      // (query on `friendCode`) works before a friendship exists. Push device
      // tokens live in the private `deviceTokens` subcollection instead.
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid
        && noAdminOnlyFieldsCreate();
      allow update: if request.auth != null && request.auth.uid == uid
        && noAdminOnlyFieldsUpdate();
      allow delete: if request.auth != null && request.auth.uid == uid;

      match /paySettings/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /gamification/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /entries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /timeEntries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /stats/{statDoc} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      match /syncDiagnostics/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /debugEvents/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /feed/{feedDoc} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      match /deviceTokens/{deviceId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /friends/{friendUid} {
        // Friend links are written ONLY by Cloud Functions (Admin SDK) via the
        // two-sided accept / reconcileFriendships flow. The previous blanket
        // `write` let any signed-in user create `users/ME/friends/VICTIM`, which
        // alone satisfies isFriendOf(VICTIM) and unlocks the victim's
        // friends-only activity and board posts. Clients may read their own
        // list and delete links (un-friend + account-deletion cleanup) only.
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create, update: if false;
        allow delete: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == friendUid);
      }

      match /friendRequests/{fromUid} {
        // Recipient can read/delete incoming requests; sender can delete a request they sent.
        allow read, delete: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == fromUid);

        // Shared invite guard — recipient must accept invites (or the field
        // is absent, which means the default is open).
        allow create, update: if request.auth != null
          && request.auth.uid == fromUid
          && request.resource.data.fromUid == fromUid
          && (
            !exists(/databases/$(database)/documents/users/$(uid))
            || !("acceptInvites" in get(/databases/$(database)/documents/users/$(uid)).data)
            || get(/databases/$(database)/documents/users/$(uid)).data.acceptInvites == true
          );
      }

      match /activity/{eventId} {
        allow read: if canReadSocialContent(uid);
        allow create, update, delete:
          if request.auth != null && request.auth.uid == uid;
      }

      match /shiftNudges/{nudgeId} {
        allow read: if request.auth != null && (
          request.auth.uid == uid
          || resource.data.fromUid == request.auth.uid
        );
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.fromUid
          && request.auth.uid != uid
          && isFriendOfAny(uid)
          && request.resource.data.fromName is string
          && request.resource.data.fromName.size() > 0
          && request.resource.data.fromName.size() <= 40
          && request.resource.data.status == 'pending'
          && request.resource.data.keys().hasOnly(['fromUid', 'fromName', 'status', 'createdAt']);
        allow update: if request.auth != null
          && request.auth.uid == uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'reacted'
          && request.resource.data.reaction is string
          && request.resource.data.reaction.size() > 0
          && request.resource.data.reaction.size() <= 8
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'reaction', 'reactedAt']);
        allow delete: if request.auth != null && (
          request.auth.uid == uid || resource.data.fromUid == request.auth.uid
        );
      }

      match /boardPosts/{postId} {
        allow read: if canReadSocialContent(uid);
        allow create: if request.auth != null
          && request.auth.uid == uid
          && validPost(request.resource.data);
        allow delete: if request.auth != null && request.auth.uid == uid;
        allow update: if request.auth != null && (
          request.auth.uid == uid
          || (
            isFriendOfAny(uid)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'commentCount'])
          )
        );

        match /comments/{commentId} {
          allow read: if canReadSocialContent(uid);
          allow create: if canReadSocialContent(uid)
            && validComment(request.resource.data);
          allow delete: if request.auth != null
            && resource.data.authorId == request.auth.uid;
          allow update: if request.auth != null
            && resource.data.authorId == request.auth.uid
            && validComment(request.resource.data);
        }
      }
    }
  }
}
