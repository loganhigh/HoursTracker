# ─── macOS ───────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Xcode / build products ──────────────────────────────
build/
DerivedData/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.xcuserstate
*.xcscmblueprint
*.xccheckout
xcuserdata/

# ─── Swift Package Manager ───────────────────────────────
.build/
.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata
Packages/
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved.orig

# ─── CocoaPods / Carthage (if ever added) ────────────────
Pods/
Carthage/Build/

# ─── Cloud Functions (Node) ──────────────────────────────
functions/node_modules/
functions/npm-debug.log*
functions/.env
functions/.env.*
!functions/.env.example

# ─── Firebase local/emulator artifacts ───────────────────
.firebase/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*

# ─── Secrets (never commit) ──────────────────────────────
*.p8
*.p12
*.mobileprovision
serviceAccountKey*.json
service-account*.json
.env
.env.*
!.env.example

# ─── Local scratch / caches / tooling ────────────────────
.derivedDataClean/
.tmp-video/
.tools/

# ─── Ruflo / claude-flow runtime (regenerated locally) ───
.claude-flow/logs/
.claude-flow/data/
.claude-flow/sessions/
.claude/memory.db

# ─── AI assistant tooling / runtime state (local only) ───
.claude/
.claude-flow/
.swarm/
.cursor/
.vscode/
.mcp.json
agentdb.rvf
agentdb.rvf.lock
ruvector.db
